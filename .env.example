# BodyShop AI — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ─── Server ────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Supabase ──────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ─── AI APIs ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...        # For embeddings (text-embedding-3-small)

# ─── Security ──────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://bodyshop-ai.railway.app,https://your-custom-domain.com

# ─── Frontend (Vite) ───────────────────────
VITE_API_URL=https://bodyshop-ai-api.railway.app
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
